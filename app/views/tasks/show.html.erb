<div class="container">
  <h1 class="mb-4 border-left border-primary pl-3"><%= @task.title %></h1>
  <div class="card mb-4">
    <div class="card-body">
      <p class="mb-3"><strong>内容:</strong><%= simple_format(@task.body) %></p>
      <p><strong>ステータス:</strong><span class="badge badge-info"><%= I18n.t("enums.task.status.#{@task.status}") %></span></p>
      <p><strong>優先度:</strong><span class="badge badge-warning"><%= I18n.t("enums.task.priority.#{@task.priority}") %></span></p>
      <p>
        <strong>期限:</strong>
        <span class="<%= 'text-danger font-weight-bold' if @task.overdue? %>">
          <%= @task.due_date&.strftime("%Y/%m/%d %H:%M") || "未設定" %>
        </span>
      </p>
      <% if @task.image.attached? %>
        <%= image_tag @task.image, size: "200x200" %>
      <% else %>
        <%= image_tag 'no_image.jpg', size: "200x200" %>
      <% end %>
    </div>
  </div>
  <div class="d-flex justify-content-between">
    <% back_path = case params[:from] when "dashboard" then root_path else tasks_path end %>
    <%= link_to "戻る", back_path, class: "btn btn-outline-secondary" %>
    <div>
      <%= link_to '編集', edit_task_path(@task), class: "btn btn-primary" %>
      <%= link_to '削除', task_path(@task), method: :delete, "data-confirm" => "本当に削除しますか？", class: "btn btn-danger" %>
    </div>
  </div>
</div>
<hr>
<div class="card mt-4">
  <div class="card-header">
    <h5 class="mb-0">コメント</h5>
  </div>
  <div class="card-body">
    <%= form_with model: [@task, Comment.new], local: true do |f| %>
      <div class="form-group">
        <%= f.text_area :body, class: "form-control", rows: 2, placeholder: "コメントを書く..." %>
      </div>
      <%= f.submit "投稿", class: "btn btn-primary btn-sm mt-2" %>
    <% end %>
    <hr>
    <% if @task.comments.any? %>
      <ul class="list-group list-group-flush">
        <% @task.comments.order(created_at: :desc).each do |comment| %>
          <li class="list-group-item d-flex justify-content-between">
            <div>
              <%= comment.user.name %>
              <p class="mb-1"><%= comment.body %></p>
              <small class="text-muted">
                <%= comment.created_at.strftime("%Y/%m/%d %H:%M") %>
              </small>
            </div>
            <% if comment.user == current_user %>
              <%= button_to "削除", task_comment_path(@task, comment), method: :delete, class: "btn btn-sm btn-danger", data: { confirm: "削除しますか？" } %>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-muted">まだコメントはありません</p>
    <% end %>
  </div>
</div>