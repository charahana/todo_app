<!DOCTYPE html>
<html>
  <head>
    <title>TodoApp</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <script src="https://kit.fontawesome.com/54104fd427.js" crossorigin="anonymous"></script>
    <%= stylesheet_pack_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
  </head>

  <body class="d-flex flex-column min-vh-100 bg-light">
    <header>
      <nav class="navbar navbar-expand-lg navbar-dark shadow-sm" style="background-color: #ff7f50;">
        <div class="container">
          <%= link_to "TodoApp", root_path, class: "navbar-brand fw-bold" %>
          <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ml-auto">
              <% if user_signed_in? %>
                <li class="nav-item dropdown">
                  <button class="btn btn-outline-light dropdown-toggle mx-2" data-toggle="dropdown">
                    <%= current_organization&.name || "組織選択"%>
                  </button>
                  <ul class="dropdown-menu dropdown-menu-end">
                    <% current_user.organizations.each do |org| %>
                      <li>
                        <%= button_to org.name, switch_organization_path(org), method: :post, class: "dropdown-item" %>
                      </li>
                    <% end %>
                    <li><hr class="dropdown-divider"></li>
                    <li><%= link_to "新しい組織", new_organization_path, class: "dropdown-item" %></li>
                  </ul>
                </li>
                <li class="nav-item">
                  <%= link_to 'アバウト', about_path, class: "nav-link text-white" %>
                </li>
                <li class="nav-item">
                  <%= link_to 'マイページ', user_path(current_user.id), class: "nav-link text-white" %>
                </li>
                <li class="nav-item">
                  <%= link_to 'タスク作成', new_task_path, class: "nav-link text-white" %>
                </li>
                <li class="nav-item">
                  <%= link_to 'タスク一覧', tasks_path, class: "nav-link text-white" %>
                </li>
                <li class="nav-item">
                  <%= link_to '組織一覧', organizations_path, class: "nav-link text-white" %>
                </li>
                <% if current_organization.present? && current_organization.memberships.find_by(user: current_user)&.admin? %>
                  <li class="nav-item">
                    <%= link_to "メンバー管理", organization_memberships_path(current_organization), class: "nav-link text-white" %>
                  </li>
                <% end %>
                <li class="nav-item">
                  <%= link_to 'ログアウト', destroy_user_session_path, method: :delete, class: "nav-link text-white" %>
                </li>
              <% else %>
                <li class="nav-item">
                  <%= link_to '新規登録', new_user_registration_path, class: "nav-link text-white" %>
                </li>
                <li class="nav-item">
                  <%= link_to 'ログイン', new_user_session_path, class: "nav-link text-white" %>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
      </nav>
    </header>
    <main class="flex-grow-1">
      <div class="container py-4">
        <% flash.each do |key, message| %>
          <div class="alert alert-<%= key == "notice" ? "success" : "danger" %> alert-dismissible fade show" role="alert">
            <%= message %>
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
              <span aria-hidden="true">&times;</span>
            </button>
          </div>
        <% end %>
        <%= yield %>
      </div>
    </main>
    <footer class="bg-dark text-light py-4 mt-auto">
      <div class="container text-center">
        <p class="mb-1">© 2026 TodoApp</p>
        <p class="small text-muted">Developed by Hanaoka</p>
      </div>
    </footer>
  </body>
</html>
