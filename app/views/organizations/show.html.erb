<h1><%= @organization.name %></h1>
<h2>メンバー一覧</h2>
<table>
  <thead>
    <tr>
      <th>ユーザー</th>
      <th>権限</th>
    </tr>
  </thead>
  <tbody>
    <% @memberships.each do |membership| %>
        <tr>
          <td><%= membership.user.name %></td>
          <td><%= membership.role %></td>
        </tr>
    <% end %>
  </tbody>
</table>
<% if @organization.memberships.find_by(user: current_user).admin? %>
  <hr>
  <h3>メンバー追加</h3>
  <%= form_with model: [@organization, @membership] do |f| %>
    <div>
      <%= f.label :user_id, "ユーザー" %>
      <%= f.collection_select :user_id, User.all, :id, :email %>
    </div>
    <div>
      <%= f.label :role %>
      <%= f.select :role, Membership.roles.keys %>
    </div>
    <%= f.submit "追加" %>
  <% end %>
<% end %>
<%= link_to "一覧に戻る", organizations_path %>