<div class="container" style="max-width: 600px;">
  <h2 class="mb-4">アカウント設定</h2>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="mb-3">
      <%= f.label :email, "メールアドレス", class: "form-label" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control" %>
    </div>

    <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
      <div class="alert alert-warning">
        確認メール送信待ち: <%= resource.unconfirmed_email %>
      </div>
    <% end %>

    <div class="mb-3">
      <%= f.label :password, "新しいパスワード", class: "form-label" %>
      <small class="text-muted">(変更しない場合は空白)</small>
      <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
      <% if @minimum_password_length %>
        <small class="text-muted">
          最低 <%= @minimum_password_length %> 文字
        </small>
      <% end %>
    </div>

    <div class="mb-3">
      <%= f.label :password_confirmation, "パスワード確認", class: "form-label" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
    </div>

    <div class="mb-4">
      <%= f.label :current_password, "現在のパスワード", class: "form-label" %>
      <small class="text-muted">(変更を保存するために必要)</small>
      <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control" %>
    </div>

    <div class="d-grid mb-4">
      <%= f.submit "更新する", class: "btn btn-primary" %>
    </div>
  <% end %>

  <hr>

  <h3 class="text-danger">アカウント削除</h3>
  <p class="text-muted">アカウントを削除すると元に戻せません。</p>
  <%= button_to "退会", registration_path(resource_name), data: { confirm: "本当に退会しますか？" }, method: :delete, class: "btn btn-danger" %>
  <div class="mt-3">
    <%= link_to "戻る", :back, class: "btn btn-outline-secondary" %>
  </div>
</div>
