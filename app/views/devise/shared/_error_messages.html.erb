<% if resource.errors.any? %>
  <div class="alert alert-danger" role="alert">
    <h5 class="mb-2"><%= resource.errors.count %>件のエラーがあります</h5>
    <ul class="mb-0">
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>